    "english",
    "i18n",
    "localization",
    "replace",
    "scan",
    "punctuation"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^9.5.0",
    "glob": "^8.1.0"
  }
