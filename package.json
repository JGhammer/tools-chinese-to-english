{
  "name": "chinese-to-english",
  "version": "1.0.0",
  "description": "Scan and replace Chinese characters in your project with English equivalents, with smart context-aware detection",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "c2e": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "node dist/test.js"
  },
